        "scripts/rebuild_docs_meta.py"
      ],
      "depends_on": [
        "system.knowledge",
        "system.roadmap"
      ]
    },
    {
      "id": "system.roadmap",
      "label": "Roadmap Tasks",
      "path": ".wiki/knowledge/system/components/roadmap.md",
      "code_paths": [
        "extensions/codewiki/index.ts",
        ".wiki/roadmap.json"
      ],
      "depends_on": [
        "system.knowledge"
      ]
    },
    {
      "id": "system.knowledge",
      "label": "Canonical Knowledge",
      "path": ".wiki/knowledge/system/components/knowledge.md",
