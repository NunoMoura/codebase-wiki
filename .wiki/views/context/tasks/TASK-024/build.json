    "id": "TASK-024",
    "title": "Sanitation checkpoints and git history policy",
    "status": "done",
    "priority": "medium",
    "kind": "architecture",
    "summary": "Keep hot wiki state small by relying on git for full history and storing only compact semantic archives and release checkpoints.",
    "labels": [
      "sanitation-policy",
      "release-checkpoints",
      "git-history"
    ],
    "goal": {
      "outcome": "CodeWiki distinguishes hot current truth, generated views, compact semantic history, and full git recovery.",
      "acceptance": [
        "Closed task archive stores compact semantic summaries with commit/release links rather than full raw context by default.",
        "Release checkpoint schema records version, git sha, canonical digest, view schema version, and closed task summaries.",
        "Docs and skills describe commit/push/version boundaries.",
        "Views exclude cold history unless explicitly requested."
      ],
      "non_goals": [
        "Duplicate full git history inside `.wiki`.",
        "Automatically push or version without policy gates."
      ],
      "verification": [
        "npm run typecheck -- --pretty false",
        "npm test"
      ]
    },
    "delta": {
      "desired": "Sanitation keeps agent hot context small while preserving semantic memory and git recovery.",
      "current": "Retention exists but archives and release/version boundaries are not fully aligned with git as full history.",
      "closure": "Archive/checkpoint policy is implemented and documented."
    }
  },
