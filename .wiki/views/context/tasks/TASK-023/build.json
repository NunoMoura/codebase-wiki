      "thinkcode-query",
      "context-etl",
      "graph-validation"
    ],
    "goal": {
      "outcome": "CodeWiki can delegate bounded query/ETL and validation tasks to ThinkCode while preserving CodeWiki semantic write boundaries.",
      "acceptance": [
        "ThinkCode role is documented in skills and runtime guidance.",
        "At least one workflow uses ThinkCode for compact context creation or graph/view validation when available.",
        "Fallback path works when ThinkCode is unavailable.",
        "ThinkCode writes remain staged or flow through CodeWiki capabilities/transactions."
      ],
      "non_goals": [
        "Make ThinkCode required for CodeWiki.",
        "Let ThinkCode edit generated views directly."
      ],
      "verification": [
