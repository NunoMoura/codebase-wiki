{
  "version": 3,
  "project_name": "codewiki",
  "template": {
    "name": "codewiki-starter",
    "version": 1,
    "generated_on": "2026-04-29"
  },
  "index_title": "codewiki Index",
  "docs_root": ".codewiki/kb",
  "specs_root": ".codewiki/kb",
  "evidence_root": ".codewiki/evidence",
  "roadmap_path": ".codewiki/roadmap.json",
  "roadmap_retention": {
    "closed_task_limit": 0,
    "archive_path": ".codewiki/roadmap/archive.jsonl",
    "compress_archive": false
  },
  "meta_root": ".codewiki",
  "views_root": ".codewiki/views",
  "sources_root": ".codewiki/sources",
  "generated_files": [
    ".codewiki/index_graph.json"
  ],
  "lint": {
    "repo_markdown": [
      "README.md",
      "extensions/codewiki/**/README.md"
    ],
    "forbidden_headings": [
      "## Purpose",
      "## When To Read",
      "## Content",
      "## Summary",
      "## How To Use This Doc"
    ],
    "word_count_warn": 1600,
    "word_count_exempt": []
  },
  "codewiki": {
    "name": "codewiki codebase wiki",
    "self_drift_scope": {
      "include": [
        ".codewiki/kb/**/*.md",
        ".codewiki/roadmap/tasks/**",
        ".codewiki/evidence/**"
      ],
      "exclude": []
    },
    "code_drift_scope": {
      "docs": [
        ".codewiki/kb/**/*.md"
      ],
      "repo_docs": [
        "README.md",
        "extensions/codewiki/**/README.md"
      ],
      "code": [
        "extensions/codewiki/**",
        "scripts/**"
      ]
    },
    "gateway": {
      "enabled": true,
      "mode": "read-only",
      "allow_paths": [
        ".codewiki/kb/**",
        ".codewiki/roadmap/tasks/**",
        ".codewiki/evidence/**",
        ".codewiki/runtime/claims.json",
        ".codewiki/index_graph.json"
      ],
      "write_paths": [
        ".codewiki/kb/**",
        ".codewiki/evidence/**"
      ],
      "generated_readonly_paths": [
        ".codewiki/index_graph.json",
        ".codewiki/roadmap/tasks/**"
      ],
      "deny_paths": [
        "**/.env*",
        "**/*secret*",
        ".codewiki/sources/private/**"
      ],
      "network": false,
      "max_stdout_bytes": 12000,
      "max_read_bytes": 200000,
      "max_write_bytes": 50000
    },
    "runtime": {
      "adapter": "codewiki-gateway-v2",
      "transaction_schema": "codewiki.transaction.v2",
      "future_executor": "think-code",
      "notes": ".codewiki/ owns all project knowledge and artifacts. .wiki/ is deprecated."
    }
  }
}
