{
  "name": "codebase-wiki",
  "version": "0.1.0",
  "description": "Pi extension and skill for repo-local codebase wiki bootstrap, rebuild, lint, and drift audits.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "documentation",
    "wiki",
    "llm",
    "agent"
  ],
  "type": "module",
  "scripts": {
    "test:smoke": "node ./scripts/smoke-test.mjs",
    "test:pack": "npm pack --dry-run",
    "test": "npm run test:smoke && npm run test:pack",
    "prepublishOnly": "npm test"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NunoMoura/codebase-wiki.git"
  },
  "bugs": {
    "url": "https://github.com/NunoMoura/codebase-wiki/issues"
  },
  "homepage": "https://github.com/NunoMoura/codebase-wiki#readme",
  "files": [
    "extensions",
    "skills",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "pi": {
    "extensions": [
      "./extensions/codebase-wiki/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
