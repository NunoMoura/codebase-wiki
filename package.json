{
	"name": "codewiki",
	"version": "0.1.2",
	"description": "Pi extension and skill for repo-local codebase wiki bootstrap, rebuild, lint, and drift audits.",
	"keywords": [
		"pi-package",
		"pi-extension",
		"documentation",
		"wiki",
		"llm",
		"agent"
	],
	"type": "module",
	"scripts": {
		"benchmark:tokens": "node ./scripts/token-benchmark.mjs",
		"test:smoke": "node ./tests/smoke/package-smoke.test.mjs && node ./tests/smoke/audit.test.mjs && node ./tests/smoke/audit-drift.test.mjs && node ./tests/smoke/resume-scheduler.test.mjs && node ./tests/smoke/prompt-assets.test.mjs",
		"test:features": "node ./tests/run.mjs",
		"test:pack": "npm pack --dry-run",
		"check:architecture": "node ./scripts/check-architecture.mjs",
		"test": "npm run check:architecture && npm run test:smoke && npm run test:features && npm run test:pack",
		"prepublishOnly": "npm test",
		"typecheck": "tsc --noEmit"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NunoMoura/codewiki.git"
	},
	"bugs": {
		"url": "https://github.com/NunoMoura/codewiki/issues"
	},
	"homepage": "https://github.com/NunoMoura/codewiki#readme",
	"files": [
		"src",
		"skills",
		"scripts",
		"README.md",
		"LICENSE",
		"package.json"
	],
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"@sinclair/typebox": "*",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "*",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=20.6.0"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"dependencies": {
		"cytoscape": "^3.33.3",
		"js-yaml": "^4.1.1"
	}
}
